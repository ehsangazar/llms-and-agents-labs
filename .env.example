# Copy to .env and fill in. The default provider is OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: point the labs at a different chat model. Model IDs are
# OpenRouter-namespaced (e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet).
LLM_MODEL=openai/gpt-4o-mini

# Optional: the two tiers Lab 1 routes between. Right-sizing needs a real gap
# between them, so keep the small one genuinely small.
LLM_MODEL_SMALL=openai/gpt-4o-mini
LLM_MODEL_LARGE=openai/gpt-4o

# The provider seam is swappable. To wire a different vendor,
# implement common/llm.ts against their SDK and set:
# LLM_PROVIDER=openrouter
LLM_PROVIDER=openrouter

# Optional: override the OpenAI-compatible base URL (defaults to OpenRouter).
# LLM_BASE_URL=https://openrouter.ai/api/v1
