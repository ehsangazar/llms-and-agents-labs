# Copy to .env and fill in. The default provider is OpenAI.
OPENAI_API_KEY=sk-...

# Optional: point the labs at a different chat model.
LLM_MODEL=gpt-4o-mini

# Optional: the two tiers Lab 1 routes between. Right-sizing needs a real gap
# between them, so keep the small one genuinely small.
LLM_MODEL_SMALL=gpt-4o-mini
LLM_MODEL_LARGE=gpt-4o

# The provider seam is swappable. To wire a different vendor,
# implement common/llm.ts against their SDK and set:
# LLM_PROVIDER=openai
LLM_PROVIDER=openai
